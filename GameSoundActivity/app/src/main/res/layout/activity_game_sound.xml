<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="20dp"
    android:background="#F0F0F0">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GAME SOUND EFFECTS"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp"
        android:textColor="#333333"/>

    <!-- Tombol Tembak -->
    <Button
        android:id="@+id/btnShoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SHOOT! 🔫"
        android:layout_marginBottom="10dp"/>

    <!-- Tombol Ledakan -->
    <Button
        android:id="@+id/btnBoom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BOOM! 💥"
        android:layout_marginBottom="10dp"/>

    <!-- Tombol Koin -->
    <Button
        android:id="@+id/btnCoin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="GET COIN! 💰"
        android:layout_marginBottom="10dp"/>

    <!-- Tombol Simultan (Semua Bunyi) -->
    <Button
        android:id="@+id/btnSimultan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PLAY ALL SIMULTANEOUSLY"
        android:layout_marginTop="30dp"
        android:backgroundTint="#FF5722"
        android:textColor="#FFFFFF"/>

</LinearLayout>